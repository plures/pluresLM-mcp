  "description": "MCP server for PluresLM — persistent distributed vector memory for AI coding assistants",
  "type": "module",
  "license": "BSL-1.1",
  "author": "Plures <hello@plures.dev>",
  "repository": {
    "type": "git",
    "url": "https://github.com/plures/pluresLM-mcp.git"
  },
  "keywords": [
    "mcp",
